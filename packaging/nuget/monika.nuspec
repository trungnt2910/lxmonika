<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>MONIKA_NUGET_PACKAGE_ID</id>
    <version>MONIKA_BUILD_VERSION</version>
    <title>LxMonika Framework</title>
    <authors>trungnt2910</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Framework for building and managing Windows Pico process providers.</description>
    <tags>Windows Pico LxMonika Monika WSL native</tags>
    <copyright>Copyright (c) MONIKA_BUILD_COPYRIGHT_YEARS MONIKA_BUILD_AUTHOR</copyright>
    <license type="expression">MIT</license>
    <readme>README.md</readme>
    <projectUrl>https://go.trungnt2910.com/monika</projectUrl>
    <repository type="git" url=MONIKA_QUOTED_BUILD_ORIGIN commit=MONIKA_QUOTED_BUILD_HASH_FULL />
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
  </metadata>
  <files>
    <file src="..\..\LICENSE.md" />

    <file src="..\..\packaging\nuget\README.CLI.md" target="README.md" />

    <!-- dotnet tool support. -->
    <file src=".\tools\**" target="tools/" />

    <!-- Move all SDK files to c\ to avoid conflicts. -->
    <!-- This matches what the Windows C++ SDK NuGet package is doing. -->
    <file src=".\bin\**" target="c/bin/" />
    <file src=".\Debug\**" target="c/Debug/" />
  </files>
</package>
